# mqlite configuration — copy to .env.local and fill in. .env.local is gitignored.
#
# DB connection. Two forms:
#   local file : MQLITE_DB=file:./mq.db   (pure-Go modernc sqlite, no CGO)
#   remote     : MQLITE_DB=libsql://<db>.turso.io  + MQLITE_DB_AUTH_TOKEN=<jwt>
#
# The connection string is read from the environment ONLY — never compiled into code.
MQLITE_DB=file:./mq.db
MQLITE_DB_AUTH_TOKEN=

# Broker auth: comma-separated static Bearer tokens accepted by `mqlite serve`.
# Clients send  Authorization: Bearer <one-of-these>
MQLITE_TOKENS=mqk_dev_local

# Client-side connection string for the Go SDK / CLI client commands:
#   mqlite://<token>@<host>:<port>?tls=true
MQLITE_ENDPOINT=http://127.0.0.1:8080
MQLITE_TOKEN=mqk_dev_local
